# 小铁配置文件示例
# 复制此文件为 config.yaml 并填入你的 API Key

# API 配置
api_key: YOUR_API_KEY_HERE
api_base: https://api.anthropic.com
model: claude-sonnet-4-20250514
provider: anthropic  # anthropic 或 openai

# Agent 配置
max_steps: 50
workspace_dir: ./workspace
system_prompt_path: system_prompt.md

# 重试配置
retry:
  enabled: true
  max_retries: 3
  initial_delay: 1.0
  max_delay: 60.0
  exponential_base: 2.0

# 缓存配置
cache:
  enabled: true
  max_size: 1000        # 最大缓存条目数
  ttl: 3600             # 缓存过期时间 (秒)
  strategy: lru         # 淘汰策略: lru, fifo

# 日志配置
logging:
  level: INFO           # DEBUG, INFO, WARNING, ERROR
  file: ~/.xiaotie/logs/xiaotie.log
  max_file_size: 10485760  # 10MB
  backup_count: 5       # 保留日志文件数
  format: "%(asctime)s [%(levelname)s] %(name)s: %(message)s"
  console: true         # 是否输出到控制台

# 工具配置
tools:
  enable_file_tools: true
  enable_bash: true
  # Charles 代理抓包工具（默认关闭）
  # enable_charles: true
  # charles_path: /Applications/Charles.app/Contents/MacOS/Charles  # 自定义路径（可选）
  # charles_proxy_port: 8888  # 自定义代理端口（可选）

  # 内置代理服务器（基于 mitmproxy，默认关闭）
  # 需要安装: pip install 'xiaotie[proxy]'
  # enable_proxy: true
  # proxy:
  #   enabled: true
  #   port: 8080                    # 代理监听端口
  #   enable_https: true            # 启用 HTTPS 拦截
  #   cert_path: ~/.xiaotie/certs   # CA 证书存储路径
  #   storage_path: ~/.xiaotie/proxy_data  # 会话数据存储路径

  # 爬虫工具（默认关闭）
  # enable_scraper: true
  # scraper:
  #   enabled: true
  #   scraper_dir: ./scrapers          # 自定义爬虫脚本目录
  #   max_workers: 4                   # 最大并发数
  #   request_delay: 1.0               # 请求间隔（秒）
  #   num_runs: 3                      # 稳定性验证运行次数
  #   stability_threshold: 0.9         # 稳定性阈值（0-1）

# --- 其他 Provider 配置示例 ---
# 取消注释并填入对应的 API Key 即可切换 Provider

# Google Gemini
# api_key: YOUR_GEMINI_API_KEY
# api_base: https://generativelanguage.googleapis.com
# model: gemini-2.0-flash
# provider: openai

# DeepSeek
# api_key: YOUR_DEEPSEEK_API_KEY
# api_base: https://api.deepseek.com
# model: deepseek-chat
# provider: openai

# 通义千问 (Qwen)
# api_key: YOUR_QWEN_API_KEY
# api_base: https://dashscope.aliyuncs.com/compatible-mode/v1
# model: qwen-plus
# provider: openai

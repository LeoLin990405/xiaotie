# 小铁 v3 配置文件示例
# 复制此文件为 config/config.yaml 后再启动
# v3 只支持 MIMO，不再支持 OpenAI / Anthropic / Gemini / DeepSeek / Qwen 等 provider

llm:
  api_key: ${env:MIMO_API_KEY}
  api_base: https://token-plan-sgp.xiaomimimo.com/anthropic
  model: mimo-v2-pro
  provider: mimo
  temperature: 0.7
  max_tokens: 4096
  retry:
    enabled: true
    max_retries: 3
    initial_delay: 1.0
    max_delay: 60.0
    exponential_base: 2.0

agent:
  max_steps: 50
  workspace_dir: ./workspace
  system_prompt_path: system_prompt.md
  thinking_enabled: false
  streaming_enabled: true
  verbose: false
  cache:
    enabled: true
    max_size: 1000
    ttl_seconds: 3600

logging:
  level: INFO
  format: "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  backup_count: 5

tools:
  enable_file_tools: true
  enable_bash: true
  enable_git: true
  enable_python: true
  enable_calculator: true
  enable_web_tools: true
  enable_code_analysis: true

  # Charles 代理抓包工具（默认关闭）
  # enable_charles: true
  # charles_path: /Applications/Charles.app/Contents/MacOS/Charles
  # charles_proxy_port: 8888

  # 内置代理服务器（基于 mitmproxy，默认关闭）
  # 需要安装: pip install 'xiaotie[proxy]'
  # enable_proxy: true
  # proxy:
  #   enabled: true
  #   port: 8080
  #   enable_https: true
  #   cert_path: ~/.xiaotie/certs
  #   storage_path: ~/.xiaotie/proxy_data

  # 爬虫工具（默认关闭）
  # enable_scraper: true
  # scraper:
  #   enabled: true
  #   scraper_dir: ./scrapers
  #   max_workers: 4
  #   request_delay: 1.0
  #   num_runs: 3
  #   stability_threshold: 0.9

  # macOS 自动化工具（默认关闭，仅 macOS）
  # enable_automation: true
  # automation:
  #   enabled: true
  #   wechat_bundle_id: com.tencent.xinWeChat
  #   screenshot_dir: ~/.xiaotie/screenshots
  #   applescript_timeout: 30
